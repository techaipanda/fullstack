# Copy this file to .env and fill in real values.
# .env is gitignored — never commit it.

# Local MongoDB (no auth):
MONGODB_URI=mongodb://127.0.0.1:27017/noteApp
TEST_MONGODB_URI=mongodb://127.0.0.1:27017/testNoteApp

# MongoDB Atlas (replace USER / PASSWORD / CLUSTER with your own):
# MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/noteApp?retryWrites=true&w=majority
# TEST_MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/testNoteApp?retryWrites=true&w=majority