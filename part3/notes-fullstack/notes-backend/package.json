    "lint": "eslint ."
  },
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "mongoose": "^9.7.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@eslint/json": "^2.0.0",
    "@stylistic/eslint-plugin-js": "^4.4.1",
    "cross-env": "^10.1.0",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "supertest": "^7.2.2"
  }
}
