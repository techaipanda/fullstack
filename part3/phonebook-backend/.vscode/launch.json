{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Launch: node index.js (stdio)",
      "program": "${workspaceFolder}/index.js",
      "transport": "stdio",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "type": "node",
      "request": "attach",
      "name": "Attach: localhost:9229",
      "address": "127.0.0.1",
      "port": 9229,
      "skipFiles": ["<node_internals>/**"]
    }
  ],
  "compounds": [
    {
      "name": "Debug Phonebook Backend",
      "configurations": ["Launch: node index.js (stdio)"]
    }
  ]
}
